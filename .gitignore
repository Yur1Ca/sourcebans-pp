# Netbeans
/nbproject/

# SourceBans++
/web/config.php
# Stashes the upgrade-e2e harness (#1269) leaves on the bind mount during a
# run; the wrapper's `trap` cleans them up on EXIT/INT/TERM but a SIGKILL or
# pre-trap crash can leave them behind.
/web/config.php.upgrade-stash
/web/config.php.upgrade-e2e-stash
/web/cache/*.php
/web/cache/*.tmp
/web/cache/sessions/sess_*
# Smarty compile dir for /updater/index.php — lands here because the script's
# CWD under Apache is `web/updater/` and init.php doesn't pin a compile dir.
# Generated by the upgrade-e2e harness (#1269); init.php's `setCompileDir`
# fix is a deferred follow-up.
/web/updater/templates_c/
*.smx

# Local Docker dev stack
/.env
/dump-*.sql
/docker-compose.override.yml

# VSCode
.vscode

# Composer vendor dir
/web/includes/vendor

# Plugin compilation
build/
release/
plugins/
.sourceknight
.venv

# Generated by .github/workflows/release.yml; runtime falls back to `git describe`
/web/configs/version.json
