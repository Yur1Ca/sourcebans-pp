			message: '#^Property Sbpp\\View\\CommsListView\:\:\$can_edit_comm is never referenced in template "page_comms\.tpl"\.$#'
			identifier: sbpp.view.unusedProperty
			count: 1
			path: includes/View/CommsListView.php

