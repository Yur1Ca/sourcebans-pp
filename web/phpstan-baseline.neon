			identifier: sbpp.view.unusedProperty
			count: 1
			path: includes/View/CommsListView.php

		-
			message: '#^Property Sbpp\\View\\AdminGroupsListView\:\:\$all_flags is never referenced in template "page_admin_groups_list\.tpl"\.$#'
			identifier: sbpp.view.unusedProperty
