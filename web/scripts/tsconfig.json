{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "strict": true,
        "strictNullChecks": true,
        "noImplicitAny": true,
        "lib": ["ES2020", "DOM", "DOM.Iterable"]
    },
    "include": ["*.js", "*.d.ts"],
    "exclude": ["node_modules"]
}
